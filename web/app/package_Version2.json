{
  "name": "aliasist-files-abductor",
  "version": "3.0.0",
  "description": "Aliasist Files Abductor — Abducting files from across the galaxy",
  "main": "main.js",
  "author": "dev_aliasist (www.aliasist.com)",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.aliasist.files.abductor",
    "productName": "Aliasist Files Abductor",
    "win": {
      "icon": "assets/alien_icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/alien_icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "renderer.js",
      "assets/**/*"
    ]
  }
}