# Copy to .env.local and fill in your keys (gitignored).
#
# Cloudflare Tunnel + Clerk (production keys): register EACH tunnel hostname as a satellite domain:
#   https://dashboard.clerk.com/~/domains  →  open "Satellites" tab  →  Add satellite domain
# (hostname only, e.g. scale-calgary-conservative-mixer.trycloudflare.com)
# Optional env overrides for primary sign-in host (defaults: auth.aliasist.com — same as DataSist / EcoSist / PulseSist).
#
# Subdomains of YOUR domain only (not tunnels): https://dashboard.clerk.com/~/domains/allowed-subdomains
#
# Redirect defaults are mostly env-driven — see https://clerk.com/docs/guides/development/customize-redirect-urls
#
VITE_GROQ_API_KEY=your_groq_api_key_here

# ── Clerk — required for Sign In on aliasist.com ─────────────────────────────
# Cloudflare Pages → your site project → Settings → Environment variables → Production:
#   VITE_CLERK_PUBLISHABLE_KEY = pk_live_… (same Clerk app as auth.aliasist.com)
# Optional Preview branch sign-in: set the same key on Preview env, OR use test keys + add preview origin below.
#
# Clerk Dashboard (same application as apps/aliasist-auth):
#   • Domains: production frontend URL includes https://aliasist.com and https://www.aliasist.com (if used)
#   • Paths / redirects: allow return to those origins after sign-in
#   • Hosted Account Portal / sign-in URL should match VITE_CLERK_PRIMARY_SIGN_* (default auth.aliasist.com)
#
# Embedded modal on aliasist.com: set proxy — navbar Sign In then stays on-page (popup OAuth) by default.
#   VITE_CLERK_PROXY_URL=https://clerk.aliasist.com/__clerk
# Optional explicit modal (same as default when proxy is set): VITE_CLERK_SIGN_IN_MODE=modal
# Force hosted Account Portal instead: VITE_CLERK_SIGN_IN_MODE=redirect
#
# Homepage Google button + One Tap (GIS): Web client ID from the Google Cloud OAuth client used by Clerk → Google SSO.
#   VITE_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
#
# Cloudflare Pages preview URL not *.aliasist.com? Add each preview origin:
#   VITE_CLERK_EXTRA_ORIGINS=https://your-hash.aliasist.pages.dev
#
VITE_CLERK_PUBLISHABLE_KEY=your_production_clerk_publishable_key
VITE_CLERK_DEV_PUBLISHABLE_KEY=your_localhost_clerk_key_optional
VITE_DEVCYCLE_CLIENT_SDK_KEY=your_devcycle_client_sdk_key_here

# Optional worker bases (defaults are baked in)
# VITE_LLM_CHAT_BASE_URL=https://your-llm-chat.workers.dev
# VITE_NEWS_WORKER_BASE_URL=https://your-news.workers.dev

# Observability — set in Cloudflare Pages → Settings → Environment variables (production)
# Never commit real DSN/tokens to git.
# VITE_SENTRY_DSN=
# VITE_SENTRY_RELEASE=aliasist-site@git-sha
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.5
# VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.05
#
# Datadog Browser RUM (optional). Session replay defaults to 0 when Sentry replay is active.
# VITE_DATADOG_APPLICATION_ID=
# VITE_DATADOG_CLIENT_TOKEN=
# VITE_DATADOG_SITE=datadoghq.com
# VITE_DATADOG_SERVICE=aliasist-site
# VITE_DATADOG_ENABLE_DEV=true

# Clerk-backed KV chat room instead of Groq LLM widget (same UI, different backend)
# VITE_USE_PAGES_CHAT_ROOM=true

# Cloudflare Pages Functions: copy `.dev.vars.example` → `.dev.vars` and add CLERK_SECRET_KEY so
# `npm run preview` can verify JWTs on `/api/*`. Production secrets go in the Pages project dashboard.
# MONGODB_URI is optional (see `/api/mongo-ping`).
# Image generation uses the Cloudflare `AI` binding in production, not a client-side API key.
