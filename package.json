{
  "name": "aliasist-files-abductor",
  "version": "3.0.0",
  "description": "Aliasist Files Abductor — Abducting files from across the galaxy",
  "main": "main.js",
  "author": "dev_aliasist (www.aliasist.com)",
  "license": "MIT",
  "scripts": {
    "start": "electron . --ozone-platform=x11",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.aliasist.files.abductor",
    "productName": "Aliasist Files Abductor",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/alien_icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/alien_icon.ico",
      "uninstallerIcon": "assets/alien_icon.ico",
      "uninstallDisplayName": "Aliasist Files Abductor",
      "createDesktopShortcut": true
    },
    "linux": {
      "icon": "assets/alien_icon.png",
      "target": ["snap", "AppImage"]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "style.css",
      "package.json",
      "assets/**/*"
    ],
    "asar": true
  }
}