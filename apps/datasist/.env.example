GROQ_API_KEY=your_groq_api_key_here

# Optional API override for local frontend development.
# Leave unset in production so the live site uses same-origin /api routes.
# VITE_DATASIST_API_BASE=https://datasist-api.bchooper0730.workers.dev

# Clerk (same instance as aliasist.com). Server JWT verification: apps/datasist-api/.dev.vars.example + wrangler secrets.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Your Clerk user id(s) for Admin tab + CRUD — must match Worker secret ADMIN_USER_IDS (comma-separated)
VITE_DATASIST_ADMIN_USER_IDS=user_xxxxxxxxxxxxxxxxxxxxxxxx
